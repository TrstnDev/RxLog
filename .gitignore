## RxLog - .gitignore (SwiftUI app built with Xcode)

# macOS
.DS_Store

# Xcode - user state
xcuserdata/
*.xcuserstate

# Xcode - build
DerivedData/
build/
*.hmap
*.ipa
*.dSYM
*.dSYM.zip
*.moved-aside

# Xcode - source control + metadata
*.xcscmblueprint
*.xccheckout

# Swift Package Manager
.build/
.swiftpm/

# Fastlane output
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/

# Repomix
.repomixignore
repomix.config.json

# Ignore local design playground target
DesignPlayground/
